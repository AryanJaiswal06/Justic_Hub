# ============================================================
#  LexBridge — .env.example
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env to version control.
# ============================================================

# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret-key

# ── JWT ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-different-strong-random-key
# Token lifetimes in seconds (3600 = 1 hour, 604800 = 7 days)
JWT_ACCESS_EXPIRES=3600
JWT_REFRESH_EXPIRES=604800

# ── Database ──────────────────────────────────────────────────
# Format: mysql+mysqlconnector://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql+mysqlconnector://root:yourpassword@localhost:3306/lexbridge

# ── Email (Gmail example) ─────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
# Your Gmail address
MAIL_USERNAME=you@gmail.com
# Use a Gmail App Password, NOT your account password
# See: https://support.google.com/accounts/answer/185833
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=noreply@lexbridge.in

# ── CORS ──────────────────────────────────────────────────────
# Development: leave blank to allow localhost origins
# Production: set to your exact frontend URL(s), comma-separated
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=

# ── File uploads ──────────────────────────────────────────────
# Absolute path or relative path from project root
UPLOAD_FOLDER=uploads

# ── App base URL ──────────────────────────────────────────────
# Used in email links — change to your production domain in prod
BASE_URL=http://localhost:5000

# ── Server port ───────────────────────────────────────────────
PORT=5000
